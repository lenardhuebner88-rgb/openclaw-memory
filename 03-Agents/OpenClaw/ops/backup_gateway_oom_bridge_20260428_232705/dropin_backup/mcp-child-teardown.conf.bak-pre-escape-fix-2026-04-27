# MCP child teardown on gateway stop/restart
# Added 2026-04-21 after discovery that QMD MCP children (bun-based, under
# .local/lib/node_modules/@tobilu/qmd/src/qmd.ts) and taskboard children accumulate
# across gateway OOM restarts, contributing ~2.3 GB RSS pressure to cgroup.
#
# Pattern covers:
#   - /home/piet/.openclaw/mcp-servers/<name>/server.js  (taskboard, future stdio MCPs)
#   - /home/piet/.local/lib/node_modules/@tobilu/qmd/src/qmd.ts mcp
#
# SIGTERM only — graceful exit. Children have stdin.on('close') handlers.
# `|| true` guards against non-zero exit tainting service state.
[Service]
ExecStopPost=/bin/sh -c 'pkill -TERM -f "mcp-servers/.+/server\.js|@tobilu/qmd/src/qmd\.ts mcp" 2>/dev/null || true'
